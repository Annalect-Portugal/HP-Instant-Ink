{
  "name": "hp-instant-ink-landing",
  "version": "1.0.0",
  "description": "HP Instant Ink landing page with Pug and SCSS",
  "scripts": {
    "dev": "powershell -ExecutionPolicy Bypass -File ./dev-watch.ps1",
    "start": "parcel src/index.pug --open",
    "build": "parcel build src/index.pug --public-url ./ --dist-dir dist",
    "build:standalone": "node build-standard.js",
    "build:worten": "node build-worten.js",
    "package": "node create-packages.js",
    "package:all": "npm run build:standalone && npm run build:worten && npm run package",
    "clean": "rimraf dist .parcel-cache worten-dist .worten-temp dist-standalone packages",
    "clean:dev": "rimraf dist .parcel-cache",
    "clean:standalone": "rimraf dist-standalone",
    "clean:worten": "rimraf worten-dist .worten-temp",
    "clean:packages": "rimraf packages",
    "prebuild:worten": "npm run clean:worten"
  },
  "devDependencies": {
    "@parcel/transformer-pug": "^2.12.0",
    "@parcel/transformer-sass": "^2.12.0",
    "archiver": "^7.0.1",
    "nodemon": "^1.0.2",
    "npm-run-all": "^1.1.3",
    "parcel": "^2.12.0",
    "pug": "^3.0.2",
    "rimraf": "^6.1.2",
    "sass": "^1.70.0"
  }
}
